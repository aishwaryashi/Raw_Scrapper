      "metadata": {
        "status": "enable",
        "adexpirystatus": "active",
        "adtimezone": "America/New_York",
        "admetroarea": "new-york-metro-area",
        "adactivedate": "2026-07-04",
        "adexpirydate": "2026-08-01",
        "intent": "find",
        "category": "room",
        "role": "I am an individual"
      },
      "user": { "uid": "u2", "displayName": "Amit S", "email": null, "phone": null, "isVerified": false, "role": "I am an individual", "business": null },
